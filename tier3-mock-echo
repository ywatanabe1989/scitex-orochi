#!/usr/bin/env python3
"""mock-echo — minimal A2A-dispatch test agent for Tier 3 verification.

Connects to the orochi hub WebSocket, joins its per-agent group, and
on receiving an ``a2a.dispatch`` envelope replies with a structured
A2A JSON-RPC echo via HTTP POST to ``/api/a2a/reply/``.

Not a Claude Code agent — just enough Python to prove the round-trip:
    NAS Django (a2a.scitex.ai)
        → orochi hub (/api/a2a/dispatch/<ws>/mock-echo)
        → AgentConsumer.a2a_dispatch
        → mock-echo WS (this script)
        → mock-echo HTTP POST /api/a2a/reply/
        → unblocks NAS waiter
        → 200 to caller

Env vars:
    SCITEX_OROCHI_HUB_URL     base http(s) URL, default https://scitex-orochi.com
    SCITEX_OROCHI_WS_URL      ws/wss URL, default wss://scitex-orochi.com/ws/agent/
    SCITEX_OROCHI_WS_TOKEN    workspace token (required)
    SCITEX_OROCHI_WS_NAME     agent name, default mock-echo

Run:
    SCITEX_OROCHI_WS_TOKEN=... ./tier3-mock-echo
"""

from __future__ import annotations

import asyncio
import json
import os
import sys
import urllib.error
import urllib.request
from datetime import datetime, timezone

import websockets

HUB_URL = os.environ.get("SCITEX_OROCHI_HUB_URL", "https://scitex-orochi.com").rstrip("/")
WS_URL = os.environ.get("SCITEX_OROCHI_WS_URL", "wss://scitex-orochi.com/ws/agent/")
WS_TOKEN = os.environ.get("SCITEX_OROCHI_WS_TOKEN", "")
AGENT_NAME = os.environ.get("SCITEX_OROCHI_WS_NAME", "mock-echo")
REPLY_URL = f"{HUB_URL}/api/a2a/reply/"


def _now_iso() -> str:
    return datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")


def _build_reply(reply_id: str, body: dict) -> dict:
    """Echo the inbound text back as a completed A2A task."""
    rpc_id = body.get("id")
    method = body.get("method", "tasks/send")
    params = body.get("params", {}) or {}
    if method != "tasks/send":
        return {
            "reply_id": reply_id,
            "result": {
                "jsonrpc": "2.0",
                "id": rpc_id,
                "error": {
                    "code": -32601,
                    "message": f"mock-echo only handles tasks/send (got {method})",
                },
            },
        }
    msg = params.get("message", {}) or {}
    parts = msg.get("parts") or []
    user_text = next(
        (p.get("text", "") for p in parts if p.get("type") == "text"),
        "",
    )
    return {
        "reply_id": reply_id,
        "result": {
            "jsonrpc": "2.0",
            "id": rpc_id,
            "result": {
                "id": f"mock-{reply_id[:12]}",
                "sessionId": params.get("sessionId"),
                "status": {
                    "state": "completed",
                    "message": None,
                    "timestamp": _now_iso(),
                },
                "history": [
                    msg,
                    {
                        "role": "agent",
                        "parts": [
                            {
                                "type": "text",
                                "text": (
                                    f"[mock-echo] received {user_text!r} via "
                                    "Tier 3 dispatch bridge (NAS → hub → WS)."
                                ),
                            }
                        ],
                    },
                ],
                "artifacts": [],
                "metadata": {
                    "x-orochi": {
                        "agent": AGENT_NAME,
                        "runtime": "tier3-mock",
                        "served_by": "orochi-hub",
                        "generated_at": _now_iso(),
                    }
                },
            },
        },
    }


def _post_reply(payload: dict) -> tuple[int, str]:
    data = json.dumps(payload).encode("utf-8")
    req = urllib.request.Request(
        REPLY_URL,
        data=data,
        method="POST",
        headers={"Content-Type": "application/json"},
    )
    try:
        with urllib.request.urlopen(req, timeout=10.0) as resp:
            return resp.status, resp.read().decode()
    except urllib.error.HTTPError as exc:
        return exc.code, exc.read().decode()
    except (urllib.error.URLError, OSError) as exc:
        return 0, str(exc)


async def main() -> int:
    if not WS_TOKEN:
        print("error: SCITEX_OROCHI_WS_TOKEN is required", file=sys.stderr)
        return 2
    url = f"{WS_URL}?token={WS_TOKEN}&agent={AGENT_NAME}"
    print(f"[mock-echo] connecting to {url.split('?')[0]}...")
    # Cloudflare BIC (Browser Integrity Check) rejects WS handshakes
    # whose User-Agent doesn't look browser-like; set a Mozilla UA so
    # the proxied tunnel passes the upgrade through to the origin.
    extra = {"User-Agent": "Mozilla/5.0 (compatible; scitex-orochi mock-echo)"}
    async with websockets.connect(url, additional_headers=extra) as ws:
        print(f"[mock-echo] connected as agent={AGENT_NAME}")
        async for raw in ws:
            try:
                msg = json.loads(raw)
            except json.JSONDecodeError:
                continue
            mtype = msg.get("type")
            if mtype == "a2a.dispatch":
                reply_id = msg.get("reply_id") or ""
                body = msg.get("body") or {}
                payload = _build_reply(reply_id, body)
                code, resp = _post_reply(payload)
                print(f"[mock-echo] handled reply_id={reply_id[:8]} -> {code}")
            elif mtype in {"ping", "pong"}:
                continue
            else:
                # ignore chat messages, presence, etc. — mock only handles A2A
                pass
    return 0


if __name__ == "__main__":
    raise SystemExit(asyncio.run(main()))
